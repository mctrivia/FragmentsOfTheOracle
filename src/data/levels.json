    "config": {
      "nodeIds": [
        "clue_crisis_sign",
        "clue_collective_son",
        "clue_poetry_matters",
        "clue_translation_gap"
      ],
      "validConnections": [
        {
          "pair": ["clue_crisis_sign", "clue_translation_gap"],
          "insight": "Isaiah's sign to Ahaz was about an immediate crisis. The word 'almah' meant young woman. When translators chose 'virgin,' a political sign became a birth prophecy — and the original audience vanished."
        },
        {
          "pair": ["clue_collective_son", "clue_poetry_matters"],
          "insight": "Hosea's 'son' was Israel. The psalmist's suffering was poetry. Both used vivid figurative language about collective experience — later readers extracted individual predictions from communal texts."
        },
        {
          "pair": ["clue_crisis_sign", "clue_collective_son"],
          "insight": "In both cases, the original subject was a known entity — a king's sign, a nation's memory. The pattern: take a line addressed to someone specific, erase that someone, and insert a future figure."
        }
      ]
    }
